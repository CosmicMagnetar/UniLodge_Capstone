## OpenRouter Configuration
OPENROUTER_API_KEY=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
OPENROUTER_MODEL=google/gemma-4-31b-it:free
# Model options for OpenRouter:
# - openai/gpt-4 (most capable)
# - openai/gpt-3.5-turbo (fast and cheap)
# - meta-llama/llama-2-7b-chat (open source)
# - mistralai/mistral-7b (open source)

# Temperature for response generation (0-2, default: 0.7)
OPENROUTER_TEMPERATURE=0.7

# RAG Configuration
RAG_ENABLED=true
RAG_TOP_K=5

# Service Configuration
NODE_ENV=development
LOG_LEVEL=debug
