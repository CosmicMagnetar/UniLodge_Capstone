# Environment Variables - Development

## Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

## Backend Configuration
NODE_ENV=development
DEBUG=true

## API Configuration
API_PORT=3000
API_HOST=localhost

## Database
DATABASE_URL=postgresql://user:password@localhost:5432/unilodge
DATABASE_POOL_SIZE=10

## Authentication
JWT_SECRET=your-jwt-secret-key-for-development
JWT_EXPIRY=7d
REFRESH_TOKEN_EXPIRY=30d

## Email Service (Optional - for future use)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=noreply@unilodge.app

## Payment Integration (Optional - for future use)
STRIPE_PUBLIC_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

## Hugging Face AI (Optional - for future use)
HUGGING_FACE_API_KEY=hf_...
HUGGING_FACE_MODEL_ENDPOINT=https://api-inference.huggingface.co/models/...

## Monitoring & Logging
SENTRY_DSN=your-sentry-dsn-here
LOGGING_LEVEL=debug

## Rate Limiting
RATE_LIMIT_WINDOW=15m
RATE_LIMIT_MAX_REQUESTS=100

## CORS Configuration
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

## File Storage
STORAGE_BUCKET=unilodge-uploads
STORAGE_REGION=us-east-1

## Redis Cache (Optional)
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

## Feature Flags
ENABLE_AI_PRICING=true
ENABLE_EMAIL_NOTIFICATIONS=false
ENABLE_PAYMENT_GATEWAY=false

## Application Settings
APP_NAME=UniLodge
APP_VERSION=2.0.0
MAINTENANCE_MODE=false
